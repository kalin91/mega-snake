{
    "tasks": {
        "inputs": [
            {
                "id": "timestampFile",
                "type": "command",
                "command": "workbench.action.tasks.runTask",
                "args": {
                    "task": "Timestamp"
                }
            },
            {
                "id": "dependsOnTask",
                "type": "pickString",
                "options": [
                    "Task A",
                    "Task B"
                ],
                "default": "Task A",
                "description": "Choose the dependent task"
            }
        ],
        "version": "2.0.0",
        "tasks": [
            {
                "label": "Timestamp",
                "type": "shell",
                "command": "python3",
                "args": [
                    "-c",
                    "from datetime import datetime; print(datetime.now().strftime(\"%Y-%m-%d\"));"
                ],
                "problemMatcher": [],
                "presentation": {
                    "reveal": "never"
                },
            },
            {
                "label": "Gradle Clean Build No Tests",
                "type": "shell",
                "command": "bash",
                "args": [
                    "-c",
                    "./gradlew clean build -x test > '$PWD/workspace_temp/clean_build_no_test.log'"
                ],
                "group": "build",
                "problemMatcher": [],
                "detail": "Runs the gradle clean build task and logs the output to folder/file.log"
            },
            {
                "label": "Gradle Clean Build",
                "type": "shell",
                "command": "bash",
                "args": [
                    "-c",
                    "./gradlew clean build > '$PWD/workspace_temp/clean_build.log'"
                ],
                "group": "build",
                "problemMatcher": [],
                "detail": "Runs the gradle clean build task and logs the output to folder/file.log"
            },
            {
                "label": "Run Java App with Debugger and Log Output",
                "type": "shell",
                "command": "bash",
                "args": [
                    "-c",
                    "java -agentlib:jdwp=transport=dt_socket,server=y,suspend=n,address=5005 -Dspring.profiles.active=stage -Dspring.config.additional-location=workspace_temp/secrets/stage/applicationSecrets.yml -jar ${config:jarFilePath} > '$PWD/workspace_temp/java_debug.log' 2>&1"
                ],
                "problemMatcher": [],
                "isBackground": false,
                "group": {
                    "kind": "build",
                    "isDefault": true
                },
                "detail": "Runs the Java app with debugger and redirects output to java.log"
            }
        ]
    }
}