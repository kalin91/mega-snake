                "default": true
            },
            {
                "name": "JavaSE-17",
                "path": "/Library/Java/JavaVirtualMachines/temurin-17.jdk/Contents/Home",
                "default": false
            },
            {
                "name": "JavaSE-17",
                "path": "/Library/Java/JavaVirtualMachines/jdk-17.jdk/Contents/Home",
                "default": false
            },
            {
                "name": "JavaSE-11",
                "path": "/Users/carlosmorales/Library/Java/JavaVirtualMachines/temurin-11.0.22/Contents/Home",
                "default": false
            },
            {
                "name": "JavaSE-11",
                "path": "/Library/Java/JavaVirtualMachines/jdk-11.0.2.jdk/Contents/Home",
                "default": false
            },
            {
                "name": "JavaSE-1.8",
                "path": "/Users/carlosmorales/Library/Java/JavaVirtualMachines/corretto-1.8.0_402/Contents/Home",
                "default": false
            }
        ],
        "java.import.gradle.home": "/opt/homebrew/Cellar/gradle@8.4/8.4/libexec",
        "terminal.integrated.env.osx": {
            "JAVA_HOME": "/Users/carlosmorales/Library/Java/JavaVirtualMachines/temurin-19.0.2/Contents/Home",
            "GRADLE_HOME": "/opt/homebrew/Cellar/gradle@8.4/8.4/libexec"
        },
        "java.import.gradle.java.home": "/Users/carlosmorales/Library/Java/JavaVirtualMachines/temurin-19.0.2/Contents/Home",
        "java.import.gradle.wrapper.enabled": false,
        "java.format.settings.url": "cwd_path/.vscode/java-formatter.xml"
    },
    "extensions": {
        "recommendations": [
            "augustocdias.tasks-shell-input",
            "berublan.vscode-log-viewer",
            "bradzacher.vscode-copy-filename",
            "github.vscode-github-actions",
            "github.vscode-pull-request-github",
            "graphql.vscode-graphql-syntax",
            "graphql.vscode-graphql",
            "letmaik.git-tree-compare",
            "mhutchie.git-graph",
            "natqe.reload",
            "sandcastle.vscode-open",
            "solomonkinard.git-blame",
            "vscjava.vscode-gradle",
            "vscjava.vscode-java-pack"
        ]
    },
    "tasks": {
        "version": "2.0.0",
        "inputs": [
            {
                "id": "todayTimestamp",
                "type": "command",
                "command": "shellCommand.execute",
                "args": {
                    "command": "python3 -c 'from datetime import datetime; print(datetime.now().strftime(\"%Y-%m-%d\"));'",
                    "useSingleResult": true
                }
            },
            {
                "id": "selectBuildTask",
                "type": "command",
                "command": "workbench.action.tasks.runTask",
                "args": {
                    "task": "Java-debug: "
                }
            }
        ],
        "tasks": [
            {
                "label": "No Build",
                "hide": true,
                "detail": "No build task",
                "problemMatcher": [],
                "type": "shell",
                "command": "echo",
                "args": [
                    "Skipping Gradle Building"
                ]
            },
            {
                "label": "Gradle Build No Test",
                "hide": true,
                "detail": "Run a gradle clean build without tests",
                "problemMatcher": [],
                "type": "shell",
                "command": "${config:java.import.gradle.home}/bin/gradle",
                "args": [
                    "clean",
                    "build",
                    "-x",
                    "test",
                    ">",
                    "'/root/parent_folder/some_path/logs/clean_build_no_test_${input:todayTimestamp}.log'",
                    "2>&1"
                ],
                "group": "build",
                "windows": {
                    "command": "${config:java.import.gradle.home}/bin/gradle.bat",
                    "args": [
                        "clean",
                        "build",
                        "-x",
                        "test",
                        ">",
                        "'/root/parent_folder/some_path/logs/clean_build_no_test_${input:todayTimestamp}.log'",
                        "2>&1"
                    ]
                }
            },
            {
                "label": "Gradle Build",
                "hide": true,
                "detail": "Run a gradle clean build",
                "problemMatcher": [],
                "type": "shell",
                "command": "${config:java.import.gradle.home}/bin/gradle",
                "args": [
                    "clean",
                    "build",
                    ">",
                    "'/root/parent_folder/some_path/logs/clean_build_${input:todayTimestamp}.log'",
                    "2>&1"
                ],
                "group": "build",
                "windows": {
                    "command": "${config:java.import.gradle.home}/bin/gradle.bat",
                    "args": [
                        "clean",
                        "build",
                        ">",
                        "'/root/parent_folder/some_path/logs/clean_build_${input:todayTimestamp}.log'",
                        "2>&1"
                    ]
                }
            },
            {
                "label": "Java Remote Debug Start",
                "hide": true,
                "detail": "Start a Java Remote Debug execution",
                "problemMatcher": [],
                "type": "shell",
                "command": "java",
                "args": [
                    "-agentlib:jdwp=transport=dt_socket,server=y,suspend=n,address=${config:mgsnake.java.remoteDebug.port}",
                    "-Dspring.profiles.active=${config:mgsnake.java.remoteDebug.profile}",
                    "-jar",
                    "${config:mgsnake.java.remoteDebug.jar}",
                    ">",
                    "'/root/parent_folder/some_path/logs/java_debug_${input:todayTimestamp}.log'",
                    "2>&1"
                ],
                "isBackground": false
            },
            {
                "label": "1 - Java-debug: Gradle Build No Test",
                "hide": false,
                "detail": "Debug java while building gradle without tests",
                "problemMatcher": [],
                "dependsOn": [
                    "Gradle Build No Test",
                    "Java Remote Debug Start"
                ],
                "dependsOrder": "sequence"
            },
            {
                "label": "2 - Java-debug: No Build",
                "hide": false,
                "detail": "Debug java without building gradle",
                "problemMatcher": [],
                "dependsOn": [
                    "No Build",
                    "Java Remote Debug Start"
                ],
                "dependsOrder": "sequence"
            },
            {
                "label": "3 - Java-debug: Gradle Build",
                "hide": false,
                "detail": "Debug java while building gradle",
                "problemMatcher": [],
                "dependsOn": [
                    "Gradle Build",
                    "Java Remote Debug Start"
                ],
                "dependsOrder": "sequence"
            },
            {
                "label": "Run Java Debug",
                "hide": false,
                "detail": "Debug java application",
                "problemMatcher": [],
                "type": "process",
                "command": "${input:selectBuildTask}"
            },
            {
                "label": "Maven Clean Install",
                "hide": false,
                "detail": "Run maven clean install",
                "problemMatcher": [],
                "type": "shell",
                "command": "${config:maven.executable.path}",
                "args": [
                    "clean",
                    "install",
                    ">",
                    "'/root/parent_folder/some_path/logs/maven_clean_install_${input:todayTimestamp}.log'",
                    "2>&1"
                ],
                "group": "build"
            },
            {
                "label": "Maven Test",
                "hide": false,
                "detail": "Run maven test",
                "problemMatcher": [],
                "type": "shell",
                "command": "${config:maven.executable.path}",
                "args": [
                    "test",
                    ">",
                    "'/root/parent_folder/some_path/logs/maven_test_${input:todayTimestamp}.log'",
                    "2>&1"
                ],
                "group": "build"
            },
            {
                "label": "Maven Verify",
                "hide": false,
                "detail": "Run maven verify",
                "problemMatcher": [],
                "type": "shell",
                "command": "${config:maven.executable.path}",
                "args": [
                    "verify",
                    ">",
                    "'/root/parent_folder/some_path/logs/maven_verify_${input:todayTimestamp}.log'",
                    "2>&1"
                ],
                "group": "build"
            },
            {
                "label": "Maven Dependency Tree",
                "hide": false,
                "detail": "Run maven dependency:tree",
                "problemMatcher": [],
                "type": "shell",
                "command": "${config:maven.executable.path}",
                "args": [
                    "dependency:tree",
                    ">",
                    "'/root/parent_folder/some_path/logs/maven_dependency_tree_${input:todayTimestamp}.log'",
                    "2>&1"
                ],
                "group": "build"
            },
            {
                "label": "Maven Spring Boot Run",
                "hide": false,
                "detail": "Run maven spring-boot:run",
                "problemMatcher": [],
                "type": "shell",
                "command": "${config:maven.executable.path}",
                "args": [
                    "spring-boot:run",
                    ">",
                    "'/root/parent_folder/some_path/logs/maven_spring_boot_${input:todayTimestamp}.log'",
                    "2>&1"
                ],
                "group": "build"
            }
        ]
    },
    "launch": {
        "version": "0.2.0",
        "inputs": [
            {
                "id": "todayTimestamp",
                "type": "command",
                "command": "shellCommand.execute",
                "args": {
                    "command": "python3 -c 'from datetime import datetime; print(datetime.now().strftime(\"%Y-%m-%d\"));'",
                    "useSingleResult": true
                }
            }
        ],
        "configurations": [
            {
                "name": "JAVA DEBUG (Attach)",
                "type": "java",
                "request": "attach",
                "port": "${config:mgsnake.java.remoteDebug.port}",
                "hostName": "localhost",
                "projectName": "stuff"
            },
            {
                "name": "PYTHON DEBUG (File)",
                "type": "debugpy",
                "request": "launch",
                "args": "> '/root/parent_folder/some_path/logs/output_${input:todayTimestamp}.log' 2>&1",
                "program": "${file}"
            },
            {
                "name": "PYTHON DEBUG (Module)",
                "type": "debugpy",
                "request": "launch",
                "env": {
                    "PYTHONPATH": "${fileDirnameBasename}"
                },
                "args": "> '/root/parent_folder/some_path/logs/output_${input:todayTimestamp}.log' 2>&1",
                "module": "${fileDirnameBasename}"
            },
            {
                "name": "PYTHON DEBUG (Snake)",
                "type": "debugpy",
                "request": "launch",
                "args": "--shell Windows -l debug msg hello world!",
                "module": "py",
                "python": "/Users/carlosmorales/IdeaProjects/stuff:/Users/carlosmorales/IdeaProjects/stuff:/Users/carlosmorales/IdeaProjects/stuff/.venv/bin/python3.13",
                "console": "integratedTerminal"
            }
        ]
    }
}