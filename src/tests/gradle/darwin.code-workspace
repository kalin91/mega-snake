{
    "folders": [
        {
            "path": ".",
            "name": "main"
        }
        //this has comments
    ],
    "settings": {
        "git-blame.gitWebUrl": "https://github.com/kalin91/unix-scripts/tree/$ID",
        "githubPullRequests.queries": [
            {
                "label": "My Closed PRs",
                "query": "is:closed author:${user}"
            },
            {
                "label": "Waiting for My Review",
                "query": "is:open review-requested:${user}"
            },
            {
                "label": "Assigned to Me",
                "query": "is:open assignee:${user}"
            },
            {
                "label": "Created by Me",
                "query": "is:open author:${user}"
            }
        ],
        "githubIssues.queries": [
            {
                "label": "My Issues",
                "query": "is:open assignee:${user} repo:${owner}/${repository}",
                "groupBy": [
                    "milestone"
                ]
            },
            {
                "label": "Created Issues",
                "query": "author:${user} state:open repo:${owner}/${repository} sort:created-desc"
            },
            {
                "label": "Recent Issues",
                "query": "state:open repo:${owner}/${repository} sort:updated-desc"
            }
        ],
        "logViewer.watch": [
            {
                "title": "GRADLE CLEAN BUILD NO TEST",
                "pattern": "/root/parent_folder/some_path/logs/clean_build_no_test_*.log",
                "autoScroll": true
            },
            {
                "title": "GRADLE CLEAN BUILD",
                "pattern": "/root/parent_folder/some_path/logs/clean_build_*.log",
                "autoScroll": true
            },
            {
                "title": "GENERIC LOG",
                "pattern": "/root/parent_folder/some_path/logs/output_*.log",
                "autoScroll": true
            },
            {
                "title": "JAVA DEBUG LOG",
                "pattern": "/root/parent_folder/some_path/logs/java_debug_*.log",
                "autoScroll": true
            },
            {
                "title": "PYTHON SNAKE LOG",
                "pattern": "/root/parent_folder/some_path/logs/python_snake_*.log",
                "autoScroll": true
            },
            {
                "title": "MAVEN CLEAN INSTALL",
                "pattern": "/root/parent_folder/some_path/logs/maven_clean_install_*.log",
                "autoScroll": true
            },
            {
                "title": "MAVEN TEST",
                "pattern": "/root/parent_folder/some_path/logs/maven_test_*.log",
                "autoScroll": true
            },
            {
                "title": "MAVEN VERIFY",
                "pattern": "/root/parent_folder/some_path/logs/maven_verify_*.log",
                "autoScroll": true
            },
            {
                "title": "MAVEN DEPENDENCY TREE",
                "pattern": "/root/parent_folder/some_path/logs/maven_dependency_tree_*.log",
                "autoScroll": true
            },
            {
                "title": "MAVEN SPRING BOOT RUN",
                "pattern": "/root/parent_folder/some_path/logs/maven_spring_boot_*.log",
                "autoScroll": true
            }
        ],
        "mgsnake.java.remoteDebug.port": 5005,
        "mgsnake.java.remoteDebug.profile": "dev",
        "mgsnake.java.remoteDebug.jar": "build/libs/*.jar",
        "terminal.integrated.scrollback": 9000,
        "editor.largeFileOptimizations": false,
        "editor.maxTokenizationLineLength": 2000000,
        "logViewer.followTailMode": "auto",
        "logViewer.chunkSizeKb": 81920,
        "java.jdt.ls.vmargs": "-XX:+UseParallelGC -XX:GCTimeRatio=4 -XX:AdaptiveSizePolicyWeight=90 -Dsun.zip.disableMemoryMapping=true -Xmx4G -Xms100m -Xlog:disable",
        "files.associations": {
            "**/.github/workflows/*.yml": "github-actions-workflow",
            "*.yml": "yaml",
            "*.gradle": "gradle"
        },
        "java.configuration.runtimes": [
            {
                "name": "JavaSE-21",
                "path": "/Library/Java/JavaVirtualMachines/temurin-21.jdk/Contents/Home",
                "default": false
            },
            {
                "name": "JavaSE-21",
                "path": "/Users/carlosmorales/Library/Java/JavaVirtualMachines/openjdk-21.0.2/Contents/Home",
                "default": false
            },
            {
